{
  "name": "noxis-hub",
  "version": "13.0.0",
  "description": "Noxis Industrial ERP Hub",
  "author": "NOXIS Labs",
  "private": true,
  "main": "dist-electron/electron/main.js",
  "scripts": {
    "dev": "next dev --turbo",
    "build": "node scripts/build-static.mjs",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "audit:check": "npm audit --audit-level=high",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run src/tests/integration",
    "test:smoke": "vitest run src/tests/integration --reporter=verbose",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "test:ci": "vitest run --reporter=junit --outputFile=test-results.xml",
    "compile:electron": "tsc -p electron/tsconfig.json",
    "seed:demo": "npx ts-node scripts/seed-demo-data.ts",
    "clean": "taskkill /F /IM Noxis.exe /T /FI \"STATUS eq RUNNING\" >NUL 2>NUL & rimraf dist dist-electron & ver > NUL",
    "electron:dev": "npm run compile:electron && electron .",
    "verify:build": "node scripts/verify-build.js",
    "verify:package": "node scripts/verify-build.js --package",
    "clean:standalone:sqlite": "node scripts/clean-standalone-sqlite.js",
    "electron:rebuild:sqlite": "npx @electron/rebuild -v 41.4.0 -o better-sqlite3-multiple-ciphers,better-sqlite3",
    "electron:build": "npm run clean && npm run compile:electron && node scripts/build-electron.mjs && npm run clean:standalone:sqlite && npm run electron:rebuild:sqlite && npm run verify:build && electron-builder -c.npmRebuild=false",
    "electron:package": "electron-builder -c.npmRebuild=false",
    "electron:rebuild": "electron-builder install-app-deps",
    "electron:publish": "npm run compile:electron && node scripts/build-electron.mjs && npm run clean:standalone:sqlite && npm run electron:rebuild:sqlite && npm run verify:build && electron-builder -c.npmRebuild=false --publish always",
    "electron:release": "npm run compile:electron && node scripts/build-electron.mjs && npm run clean:standalone:sqlite && npm run electron:rebuild:sqlite && npm run verify:build && electron-builder -c.npmRebuild=false --publish onTag",
    "postinstall": "node -e \"if (!process.env.CI && !process.env.CF_PAGES && !process.env.CLOUDFLARE_DEPLOY) { require('child_process').execSync('electron-builder install-app-deps', { stdio: 'inherit' }); } else { console.log('Skipping Electron native dependency rebuilds on Cloudflare/CI environment'); }\"",
    "license:generate": "npx ts-node scripts/generate-license.ts",
    "license:trial": "npx ts-node --compiler-options \"{\\\"module\\\": \\\"commonjs\\\"}\" scripts/generate-license.ts --trial",
    "license:test": "npx ts-node scripts/test-license.ts",
    "mobile:init": "npm install @capacitor/core @capacitor/cli && npx cap init \"Noxis Hub\" \"com.omnora.noxishub\" --web-dir=out",
    "mobile:add-android": "npm install @capacitor/android && npx cap add android",
    "mobile:build": "npm run build && npx cap sync android",
    "mobile:open": "npx cap open android",
    "doctor": "npx react-doctor@latest"
  },
  "dependencies": {
    "@capacitor/core": "^8.3.1",
    "@hookform/resolvers": "^3.3.4",
    "@parcel/watcher": "^2.5.6",
    "@pdf-lib/fontkit": "^1.1.1",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@sentry/electron": "^7.13.0",
    "@sentry/nextjs": "^10.51.0",
    "@stripe/react-stripe-js": "^6.3.0",
    "@stripe/stripe-js": "^9.4.0",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.105.1",
    "@tanstack/react-query": "^5.100.7",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.13.24",
    "@types/dotenv": "^6.1.1",
    "@types/file-saver": "^2.0.7",
    "@types/jsbarcode": "^3.11.4",
    "@types/recharts": "^1.8.29",
    "better-sqlite3": "^12.9.0",
    "better-sqlite3-multiple-ciphers": "^12.11.1",
    "browserify-fs": "^1.0.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "decimal.js": "^10.6.0",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "echarts": "^6.0.0",
    "electron-log": "^5.4.3",
    "electron-updater": "^6.8.3",
    "file-saver": "^2.0.5",
    "framer-motion": "^12.38.0",
    "fuse.js": "^7.3.0",
    "heic-convert": "^2.1.0",
    "jsbarcode": "^3.12.3",
    "jspdf": "^4.2.1",
    "jszip": "^3.10.1",
    "lucide-react": "^1.17.0",
    "mammoth": "^1.12.0",
    "next": "16.2.4",
    "next-intl": "^4.11.2",
    "node-cron": "^3.0.3",
    "papaparse": "^5.5.3",
    "pdf-lib": "^1.17.1",
    "pg": "^8.21.0",
    "pino": "^9.0.0",
    "png-to-ico": "^3.0.1",
    "pptxgenjs": "^4.0.1",
    "qrcode": "^1.5.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-dropzone": "^15.0.0",
    "react-hook-form": "^7.51.0",
    "react-joyride": "^3.1.0",
    "react-zxing": "^1.1.3",
    "recharts": "^3.8.1",
    "serve-static": "^2.2.1",
    "stripe": "^22.1.0",
    "tailwind-merge": "^3.5.0",
    "tesseract.js": "^7.0.0",
    "xlsx": "^0.18.5",
    "zod": "^3.22.4",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@capacitor/android": "^8.3.1",
    "@capacitor/cli": "^8.3.1",
    "@next/bundle-analyzer": "^16.2.4",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/jszip": "^3.4.0",
    "@types/node": "^24.10.1",
    "@types/node-cron": "^3.0.11",
    "@types/papaparse": "^5.5.2",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-dropzone": "^4.2.2",
    "@types/testing-library__jest-dom": "^5.14.9",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.10",
    "drizzle-kit": "^0.20.0",
    "electron": "^41.4.0",
    "electron-builder": "^26.8.1",
    "electron-icon-builder": "^2.0.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "jsdom": "^29.1.1",
    "jsonwebtoken": "^9.0.3",
    "rimraf": "^6.1.3",
    "sharp": "^0.34.5",
    "tailwindcss": "^4",
    "ts-node": "^10.9.2",
    "typescript": "^5",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  },
  "build": {
    "appId": "com.omnora.noxishub",
    "productName": "Noxis Hub",
    "npmRebuild": false,
    "directories": {
      "output": "dist"
    },
    "files": [
      "dist-electron/**/*",
      "out/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": ".next/standalone",
        "to": "standalone",
        "filter": [
          "**/*"
        ]
      }
    ],
    "asar": true,
    "asarUnpack": [
      "**/standalone/**/*",
      "**/node_modules/better-sqlite3/**/*",
      "**/node_modules/better-sqlite3-multiple-ciphers/**/*"
    ],
    "win": {
      "target": "nsis"
    }
  }
}
