{
  "name": "noxis-hub-deploy-root",
  "private": true,
  "packageManager": "npm@10.9.2",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "npm run build --prefix omnora-prime-v13",
    "cf:deploy": "npm run build && wrangler deploy",
    "cf:pages": "npm run build && wrangler pages deploy omnora-prime-v13/out --project-name=noxishub"
  },
  "devDependencies": {
    "wrangler": "^4.95.0"
  }
}
